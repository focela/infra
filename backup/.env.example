# Backup configuration for npm-backup.sh.
# Copy to backup/.env and fill in values. Do not commit backup/.env.

# ---------------------------------------------------------------------------
# S3 destination
# ---------------------------------------------------------------------------
# S3-compatible destination (AWS S3, Cloudflare R2, MinIO, etc.)
BACKUP_S3_BUCKET=s3://your-bucket/npm-backups

# Required for Cloudflare R2, MinIO, or any non-AWS S3-compatible endpoint.
# Leave unset for standard AWS S3.
# AWS_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# AWS credentials
# ---------------------------------------------------------------------------
# Option A — explicit keys (IAM user with s3:PutObject + s3:DeleteObject + s3:ListBucket).
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-southeast-1

# Option B — EC2/GCP instance role attached to the VM; no keys needed, leave all above unset.

# Option C — ~/.aws/credentials on the host; leave all above vars unset.

# ---------------------------------------------------------------------------
# Retention and paths
# ---------------------------------------------------------------------------
# Number of days to retain backups on S3 (default: 14).
BACKUP_RETENTION=14

# Override if stacks/proxy is not under the repo root (optional).
# BACKUP_STACK_DIR=/absolute/path/to/stacks/proxy
