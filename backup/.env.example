# Shared backup configuration.
# Copy to backup/.env and set environment values. Do not commit backup/.env.

# S3-compatible backup destination.
BACKUP_S3_BUCKET=s3://your-bucket/infra-backups

# Required for Cloudflare R2, MinIO, or any non-AWS S3-compatible endpoint.
# Leave unset for standard AWS S3.
# AWS_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# AWS credentials
# Option A: explicit credentials for an IAM user with S3 backup permissions.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-southeast-1

# Option B: instance profile attached to the VM.

# Option C: ~/.aws/credentials on the host.

# Retention and paths
# Number of days to retain backups on S3 (default: 14).
BACKUP_RETENTION=14

# Stack path overrides.
# PROXY_STACK_DIR=/absolute/path/to/stacks/proxy
# PROXY_BACKUP_DATA_DIR=/srv/infra/proxy/data
# WIREGUARD_STACK_DIR=/absolute/path/to/stacks/wireguard
# WIREGUARD_BACKUP_DATA_DIR=/srv/infra/wireguard/data
