# WireGuard stack. Copy to .env and set environment values.
# .env is gitignored; do not commit it.

# Public IP or DNS name of this VM. Use the Elastic IP or a DNS record.
# Set to "auto" to let the image detect the endpoint on first start.
WG_SERVER_URL=auto

# UDP port WireGuard listens on. Must be open in the security group.
WG_SERVER_PORT=51820

# Number of peer configs to generate (one per team member).
# Increase and restart to generate additional peers; existing peers are unchanged.
WG_PEERS=5

# DNS server pushed to peer configs.
# "auto" uses the WireGuard server itself and routes DNS through the tunnel.
# Use a public DNS server when peer DNS should bypass the tunnel.
WG_PEER_DNS=1.1.1.1

# Host path for WireGuard keys and peer configs.
# Use an absolute path on production hosts (e.g. /srv/infra/wireguard/data).
# Contains private keys. Protect access to this directory.
WIREGUARD_DATA_DIR=./data
