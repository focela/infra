# Nginx Proxy Manager. Copy this file to `.env` and set real values.
# `.env` is gitignored; do not commit it.

# Initial admin account, used only on first boot.
# After login, change the password in the UI and consider removing these two variables.
INITIAL_ADMIN_EMAIL=admin@focela.com
INITIAL_ADMIN_PASSWORD=change-me-to-a-strong-password

# Disable IPv6 if the host has no IPv6 (prevents nginx startup errors).
DISABLE_IPV6=true
