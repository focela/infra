# Nginx Proxy Manager. Copy to .env and set environment values.
# `.env` is gitignored; do not commit it.

# Initial admin account, used only on first boot.
# After first login, change the password in the UI.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-to-a-strong-password

# Host path for NPM state. Use an absolute path such as
# /srv/infra/proxy/data on production hosts.
PROXY_DATA_DIR=./data

# Set true on hosts without IPv6 to prevent nginx startup errors.
DISABLE_IPV6=true
