# Production: ap-southeast-1
# Copy to terraform.tfvars for local use. Do not commit terraform.tfvars.

region               = "ap-southeast-1"
prefix               = "infra"
vpc_cidr             = "10.0.0.0/16"
vm_ops_instance_type = "t3.small"

# SSH public key for SSH-over-SSM access.
# Leave empty to skip authorized_keys configuration.
ssh_public_key = ""
