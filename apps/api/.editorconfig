# EditorConfig: https://editorconfig.org
# Codifies the formatting already produced by the IDE defaults + lombok.config.
# Do not change without coordinating across the team — every file in the
# tree was authored under these settings.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
