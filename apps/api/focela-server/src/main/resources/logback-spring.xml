<configuration>
    <!-- Based on org/springframework/boot/logging/logback/defaults.xml; tunes CONSOLE_LOG_PATTERN and FILE_LOG_PATTERN. -->
    <!-- Format tokens: %d=date, %thread=thread name, %-5level=level padded to 5 chars, %msg=log message, %n=newline. -->
    <!-- CONSOLE_LOG_PATTERN adds highlight/cyan ANSI colors compared with FILE_LOG_PATTERN. -->
    <property name="CONSOLE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{50}:%L) - %msg%n"/>
    <property name="FILE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%L - %msg%n"/>

    <!-- Console Appender -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- File Appender -->
    <!-- Modeled after Spring Boot's file-appender.xml. -->
    <appender name="FILE"  class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>
        <!-- Log file name -->
        <file>${LOG_FILE}</file>
        <!-- Rolling policy: roll files based on day + size. -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern> <!-- Log file output name pattern -->
            <maxHistory>30</maxHistory> <!-- Number of days log files are retained -->
            <maxFileSize>10MB</maxFileSize> <!-- File size at which a log file is rolled -->
        </rollingPolicy>
    </appender>
    <!-- Async log writes for better performance. -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold> <!-- Do not discard logs. By default, once the queue is 80% full, TRACE/DEBUG/INFO logs are dropped. -->
        <queueSize>512</queueSize> <!-- Override the default queue depth; affects performance. Default is 256. -->
        <appender-ref ref="FILE"/>
    </appender>

    <!-- SkyWalking Appender: GRPC log collection for a centralized log service. -->
    <!--
    <appender name="SKYWALKING" class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.log.GRPCLogClientAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.TraceIdPatternLogbackLayout">
                <pattern>[%tid] ${FILE_LOG_PATTERN}</pattern>
            </layout>
        </encoder>
    </appender>
    -->

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <!-- In local environments, comment this out if you do not want FILE logging. -->
        <appender-ref ref="ASYNC"/>
        <!-- Uncomment to enable the SkyWalking log service. -->
        <!-- <appender-ref ref="SKYWALKING"/> -->
    </root>

</configuration>
